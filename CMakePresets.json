{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON"
            }
        },
        {
            "name": "clang-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/_build-${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang-18",
                "CMAKE_CXX_COMPILER": "clang++-18",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++"
            }
        },
        {
            "name": "clang-debug",
            "inherits": "clang-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "clang-release",
            "inherits": "clang-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
		{
			"name": "msvc",
			"inherits": "base",
			"displayName": "MSVC - Visual Studio generator (MSBuild)",
			"description": "Configure using Visual Studio generator (selects MSBuild).",
			"generator": "Visual Studio 17 2022",
			"binaryDir": "${sourceDir}/_build-${presetName}",
			"cacheVariables": {
				"CMAKE_GENERATOR_PLATFORM": "x64"
			}
		}
    ],
    "buildPresets": [
        {
            "name": "build-clang-debug",
            "configurePreset": "clang-debug",
            "targets": [
                "all"
            ]
        },
        {
            "name": "build-clang-release",
            "configurePreset": "clang-release",
            "targets": [
                "all"
            ]
        },
		{
			"name": "build-msvc-debug",
			"displayName": "Build (MSVC Debug)",
			"configurePreset": "msvc",
			"configuration": "Debug",
			"jobs": 4
		},
		{
			"name": "build-msvc-release",
			"displayName": "Build (MSVC Release)",
			"configurePreset": "msvc",
			"configuration": "Release",
			"jobs": 4
		}
    ]
}